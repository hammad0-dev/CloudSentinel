{
  "name": "cloudsentinel",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c cyan,magenta \"npm run dev -w cloudsentinel-backend\" \"npm run dev -w cloudsentinel-frontend\"",
    "dev:backend": "npm run dev -w cloudsentinel-backend",
    "dev:frontend": "npm run dev -w cloudsentinel-frontend",
    "build": "npm run build -w cloudsentinel-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
