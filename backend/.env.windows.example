# Copy to `.env` on your Windows machine (local backend + Postgres on Windows).
# Sonar may run on Ubuntu — use SONAR_HOST = http://UBUNTU_LAN_IP:9000.

PORT=3000

# Wins over DB_* keys in db.js when set — use YOUR Windows Postgres user/password.
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD_HERE@localhost:5432/cloudsentinel

SONAR_HOST=http://192.168.141.128:9000
SONAR_TOKEN=your_sonar_token
# Stop “stuck Scanning”: optional timeouts / polling (milliseconds)
# SAST_GIT_TIMEOUT_MS=900000
# SAST_SONAR_SCAN_TIMEOUT_MS=2700000
# SAST_SONAR_HTTP_TIMEOUT_MS=90000
# SAST_SONAR_INDEX_MAX_WAIT_MS=300000
# SAST_SONAR_INDEX_POLL_MS=5000
# Mark RUNNING scans older than this FAILED on API startup (minutes). Use 0 to disable.
# Applies to BOTH SAST (scan_history) and dependency scans (dependency_scans).
# SAST_ORPHAN_RUN_MINUTES=240
#
# SAST_CONTINUE_ON_BUILD_FAILURE=true   (set false to FAIL when Maven/Gradle does not compile)
# SAST_ALLOW_EMPTY_SONAR_INDEX=true     (set false to FAIL if Sonar still shows 0 lines after index wait)
#
# If scan fails with "No files matching src/main/java": repo ships sonar-project.properties — we strip it by default.
# To keep embedded Sonar settings: SAST_USE_EMBEDDED_SONAR_PROPERTIES=true
#
# Faster SAST on large Java (e.g. WebGoat): shallow git, parallel Maven, Sonar paths
# SAST_SHALLOW_CLONE=true
# SAST_MAVEN_PARALLEL=-T 1C
# SAST_MAVEN_PARALLEL=   (empty = no -T flag)
# SAST_SONAR_EXCLUSIONS=**/node_modules/**,**/.git/**,**/k8s/**,**/helm/** (defaults already skip k8s/helm to avoid IaC sensor crashes)
# Auto-detected: Maven target/classes + Gradle build/classes/*main. Override with comma-separated paths:
# SAST_SONAR_JAVA_BINARIES=module-a/target/classes,module-b/target/classes
# SAST_GRADLE_TIMEOUT_MS=1800000
# Gradle Spring Boot (e.g. VulnerableApp): Java 17 toolchain — point to JDK 17+ on the scan machine if default java is older:
# SAST_GRADLE_JAVA_HOME=C:/Program Files/Java/jdk-17
# Gradle Spotless / Prettier issues: append extra exclusions (tasks must exist in that repo):
# SAST_GRADLE_EXTRA_ARGS=-x spotlessCheck -x spotlessJavaCheck
#
# Dependency / Trivy (large Java repos e.g. WebGoat — first run downloads vuln DB)
# DEP_GIT_TIMEOUT_MS=900000
# DEP_TRIVY_TIMEOUT_MS=3600000
CLONE_DIR=D:/temp/cloudsentinel-scans
SONAR_SCANNER_PATH=sonar-scanner
# If not on PATH, e.g.: C:/sonar-scanner/bin/sonar-scanner.bat

JWT_SECRET=cloudsentinel_super_secret_jwt_key_2024
GITHUB_TOKEN=ghp_your_github_pat_here
FRONTEND_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CloudSentinel <noreply@example.com>
