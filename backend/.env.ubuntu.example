# ═══════════════════════════════════════════════════════════════
# UBUNTU — copy this FILE to ~/CloudSentinel/backend/.env  (not the Windows .env!)
# Backend + Postgres + SonarQube run on SAME machine → SONAR_HOST=localhost
# Replace pasted secrets below (never commit real .env).
# ═══════════════════════════════════════════════════════════════

PORT=3000

SONAR_HOST=http://localhost:9000
SONAR_TOKEN=PASTE_SONAR_USER_TOKEN
CLONE_DIR=/tmp/cloudsentinel-scans
SONAR_SCANNER_PATH=sonar-scanner
# Repo sonar-project.properties can break scans (wrong sonar.sources). Stripped unless:
# SAST_USE_EMBEDDED_SONAR_PROPERTIES=true
#
# Optional SAST tuning (ms): SAST_GIT_TIMEOUT_MS, SAST_SONAR_SCAN_TIMEOUT_MS, SAST_SONAR_HTTP_TIMEOUT_MS,
# SAST_SONAR_INDEX_MAX_WAIT_MS, SAST_SONAR_INDEX_POLL_MS. Stale RUNNING cleanup on API boot: SAST_ORPHAN_RUN_MINUTES (0=off).
# Resilience (defaults favor completing a scan when possible):
# SAST_CONTINUE_ON_BUILD_FAILURE=true   # set false to FAIL if Maven/Gradle does not compile
# SAST_ALLOW_EMPTY_SONAR_INDEX=true     # set false to FAIL if Sonar still shows 0 lines after the index wait
#
# Gradle + Java 17 toolchain (e.g. hammad0-dev/VulnerableApp): install JDK 17 and point Gradle at it so ./gradlew can compile:
# SAST_GRADLE_JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
# sudo apt-get install openjdk-17-jdk-headless
#
# Gradle + Spotless/Prettier (e.g. VulnerableApp): if Gradle logs ReferenceError-like messages, exclude formatting tasks:
# SAST_GRADLE_EXTRA_ARGS=-x spotlessCheck -x spotlessJavaCheck
#
# Dependency scan (Trivy) runs ./gradlew compileJava for Gradle-only repos — same JDK as SAST:
# DEP_GRADLE_JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64   (optional; falls back to SAST_GRADLE_JAVA_HOME)
# DEP_GRADLE_COMPILE_TIMEOUT_MS=900000
# DEP_SKIP_GRADLE_COMPILE=true   # set to skip Gradle before Trivy (not recommended for Gradle SBOM)

# If GitHub "main" is empty but code is on "master" / "develop":
# GIT_CLONE_BRANCH=master

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudsentinel
DB_USER=csuser
DB_PASSWORD=cspassword123

# Optional alternative to DB_* lines (omit DB_* above if using this URL only):
# DATABASE_URL=postgresql://csuser:cspassword123@localhost:5432/cloudsentinel

JWT_SECRET=cloudsentinel_super_secret_jwt_key_2024
GITHUB_TOKEN=PASTE_GITHUB_PAT_WITH_REPO_CLONE_SCOPE
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS="your gmail app password with spaces quoted"
SMTP_FROM=CloudSentinel <your_email@gmail.com>
GOOGLE_CLIENT_ID=PASTE_IF_USED
GITHUB_OAUTH_CLIENT_ID=PASTE_IF_USED
GITHUB_OAUTH_CLIENT_SECRET=PASTE_IF_USED
