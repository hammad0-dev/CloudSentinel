# ═══════════════════════════════════════════════════════════════
# UBUNTU — copy this FILE to ~/CloudSentinel/backend/.env  (not the Windows .env!)
# Backend + Postgres + SonarQube run on SAME machine → SONAR_HOST=localhost
# Replace pasted secrets below (never commit real .env).
# ═══════════════════════════════════════════════════════════════

PORT=3000

SONAR_HOST=http://localhost:9000
SONAR_TOKEN=PASTE_SONAR_USER_TOKEN
CLONE_DIR=/tmp/cloudsentinel-scans
SONAR_SCANNER_PATH=sonar-scanner

# If GitHub "main" is empty but code is on "master" / "develop":
# GIT_CLONE_BRANCH=master

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudsentinel
DB_USER=csuser
DB_PASSWORD=cspassword123

# Optional alternative to DB_* lines (omit DB_* above if using this URL only):
# DATABASE_URL=postgresql://csuser:cspassword123@localhost:5432/cloudsentinel

JWT_SECRET=cloudsentinel_super_secret_jwt_key_2024
GITHUB_TOKEN=PASTE_GITHUB_PAT_WITH_REPO_CLONE_SCOPE
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS="your gmail app password with spaces quoted"
SMTP_FROM=CloudSentinel <your_email@gmail.com>
GOOGLE_CLIENT_ID=PASTE_IF_USED
GITHUB_OAUTH_CLIENT_ID=PASTE_IF_USED
GITHUB_OAUTH_CLIENT_SECRET=PASTE_IF_USED
